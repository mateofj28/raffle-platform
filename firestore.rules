rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Validate authenticated user with tenant claim
    function isAuthenticated() {
      return request.auth != null && request.auth.token.tenantId != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }

    function isVendor() {
      return isAuthenticated() && request.auth.token.role == 'vendor';
    }

    function belongsToTenant(tenantId) {
      return isAuthenticated() && request.auth.token.tenantId == tenantId;
    }

    // Tenant-level access
    match /tenants/{tenantId} {
      allow read: if belongsToTenant(tenantId);
      allow write: if false; // Only via Cloud Functions

      // Raffles
      match /raffles/{raffleId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if false; // Only via Cloud Functions

        // Tickets (subcollection of raffles)
        match /tickets/{ticketNumber} {
          allow read: if belongsToTenant(tenantId)
            && (isAdmin() || resource.data.vendorId == request.auth.uid);
          allow write: if false; // Only via Cloud Functions
        }
      }

      // Customers
      match /customers/{customerId} {
        allow read: if belongsToTenant(tenantId);
        allow write: if false; // Only via Cloud Functions
      }

      // Vendors
      match /vendors/{vendorId} {
        allow read: if belongsToTenant(tenantId)
          && (isAdmin() || request.auth.uid == resource.data.userId);
        allow write: if false; // Only via Cloud Functions
      }

      // Payments
      match /payments/{paymentId} {
        allow read: if belongsToTenant(tenantId)
          && (isAdmin() || resource.data.vendorId == request.auth.token.vendorId);
        allow write: if false; // Only via Cloud Functions
      }

      // Adjustments
      match /adjustments/{adjustmentId} {
        allow read: if belongsToTenant(tenantId) && isAdmin();
        allow write: if false; // Only via Cloud Functions
      }

      // Commissions
      match /commissions/{commissionId} {
        allow read: if belongsToTenant(tenantId)
          && (isAdmin() || resource.data.vendorId == request.auth.token.vendorId);
        allow write: if false; // Only via Cloud Functions
      }

      // Audit Trail
      match /auditTrail/{auditId} {
        allow read: if belongsToTenant(tenantId) && isAdmin();
        allow write: if false; // Only via Cloud Functions
      }

      // Metrics
      match /metrics/{metricId} {
        allow read: if belongsToTenant(tenantId) && isAdmin();
        allow write: if false; // Only via Cloud Functions
      }
    }
  }
}
