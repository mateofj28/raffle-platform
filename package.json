{
  "name": "raffle-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "tsx scripts/seed-admin.ts",
    "seed:emulator": "tsx scripts/seed-emulator.ts",
    "emulators": "firebase emulators:start",
    "emulators:build": "npm --prefix functions run build",
    "dev:full": "npm run emulators:build && start cmd /c \"firebase emulators:start\" && timeout /t 5 && npm run seed:emulator && npm run dev"
  },
  "dependencies": {
    "@heroui/react": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "firebase": "^12.16.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
